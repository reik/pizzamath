# Server port (default 3001)
PORT=3001

# Where the SPA is served. Used to build magic-link URLs in emails.
# Dev:  http://localhost:5175
# Prod: https://your-domain.example
APP_BASE_URL=http://localhost:5175

# JWT signing secret for session tokens — generate with `openssl rand -hex 64`
JWT_SECRET=

# Anthropic API key (for /api/claude worksheet generation)
ANTHROPIC_API_KEY=

# Resend transactional email — sign up at https://resend.com and grab an API key.
# When unset, magic-link emails are logged to stdout instead of sent.
RESEND_API_KEY=

# From-address for outgoing email. The default sandbox address only works for
# verified test recipients on Resend's free tier — set a verified domain for prod.
EMAIL_FROM=PizzaMath <onboarding@resend.dev>
